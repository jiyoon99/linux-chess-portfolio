[Unit]
Description=Linux Chess backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/linux-chess/backend
Environment=PORT=3000
ExecStart=/opt/linux-chess/backend/chess-server
Restart=on-failure
RestartSec=3
User=chess
Group=chess
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/linux-chess

[Install]
WantedBy=multi-user.target
